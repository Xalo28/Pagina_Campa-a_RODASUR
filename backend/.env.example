# Copia este archivo como ".env" y completa tus valores reales.
# NUNCA subas el archivo .env a un repositorio.

# Puerto del servidor
PORT=3000

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=rodasur

# Seguridad (CÁMBIALOS en producción)
JWT_SECRET=pon-aqui-una-cadena-larga-y-aleatoria
ADMIN_USER=admin
ADMIN_PASSWORD=una-contraseña-fuerte

# Envío de correos a suscriptores (opcional).
# Ejemplo con Brevo/SMTP; si lo dejas vacío, el envío queda desactivado.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=RODASUR <no-reply@rodasur.com>
